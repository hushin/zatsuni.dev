    "test:aria": "playwright test",
    "build:test-fixtures": "BLOG_CONTENT_DIR=tests/fixtures/blog astro build",
    "test:aria:update": "tsx tests/aria/generate-snapshots.ts"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^6.4.8",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/typography": "^0.5.20",
    "daisyui": "^5.7.0",
    "lefthook": "^2.1.10",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.110.0"
  }
