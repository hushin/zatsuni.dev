{
  "name": "zatsuni.dev",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "new-post": "node scripts/new-post.js",
    "deploy": "astro build && wrangler deploy",
